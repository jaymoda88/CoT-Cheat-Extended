{
  "name": "CotCheatMod",
  "version": "1.2.0",
  "styleFileList": [],
  "scriptFileList": [
    "js/cheat.js"
  ],
  "tweeFileList": [],
  "imgFileList": [],
  "addonPlugin": [
    {
      "modName": "TweeReplacer",
      "addonName": "TweeReplacerAddon",
      "modVersion": "^1.0.0",
      "params": [
        {
          "passage": "StoryCaption",
          "findString": "<div class=\"storymenu-debug-container\">",
          "replace": "<div class=\"fullwidth-buttons\">\n<<button \"⚙ 作弊選單\">><<run CotCheat.openMenu()>><</button>>\n</div>\n<div class=\"storymenu-debug-container\">"
        },
        {
          "passage": "Wardrobe",
          "findString": "!$lastloctags.includes(\"homebase\") and !_stripallowed && !$pc.clothes_ok(V.location, V.locationblock, false)>>",
          "replace": "!$cotNudist and !$lastloctags.includes(\"homebase\") and !_stripallowed && !$pc.clothes_ok(V.location, V.locationblock, false)>>"
        },
        {
          "passage": "Wardrobe",
          "findString": "<<elseif !$pc.skillleveled(\"Exhibitionism\", _exhibreq)>>",
          "replace": "<<elseif !$cotNudist and !$pc.skillleveled(\"Exhibitionism\", _exhibreq)>>"
        }
      ]
    }
  ],
  "dependenceInfo": [
    {
      "modName": "ModLoader",
      "version": "^2.0.0"
    },
    {
      "modName": "TweeReplacer",
      "version": "^1.0.0"
    }
  ]
}
